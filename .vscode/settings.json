{
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#0D1218",
    "titleBar.activeForeground": "#0CEEDE",
    "titleBar.inactiveBackground": "#0A0F18",
    "activityBar.background": "#0D1218",
    "activityBar.foreground": "#0CEEDE",
    "statusBar.background": "#0CEEDE",
    "statusBar.foreground": "#001A18",
    "sideBar.background": "#0A0F18",
    "editorGroupHeader.tabsBackground": "#0D1218",
    "tab.activeBackground": "#111820",
    "tab.inactiveBackground": "#0A0F18"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/build": true,
    "**/dist": true
  }
}
